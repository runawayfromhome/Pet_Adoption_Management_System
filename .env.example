# Example environment variables for local development
# Copy this to .env and fill in your own values.

SUPABASE_URL=https://your-supabase-project.supabase.co
# Preferred for backend/server use:
SUPABASE_SECRET_KEY=sb_secret_your-supabase-secret-key
# Optional/legacy alternatives supported by the app:
# SUPABASE_SERVICE_ROLE_KEY=your-legacy-service-role-jwt
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-publishable-key
# SUPABASE_ANON_KEY=your-legacy-anon-jwt
# SUPABASE_KEY=your-supabase-key
SUPABASE_STORAGE_BUCKET=pet-assets
SUPABASE_DB_URL=postgresql://postgres:<db-password>@db.<project-ref>.supabase.co:5432/postgres
# Optional legacy alias supported by the app:
# DATABASE_URL=postgresql://postgres:<db-password>@db.<project-ref>.supabase.co:5432/postgres

SECRET_KEY=your-secret-key
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-email-password
MAIL_DEFAULT_SENDER=office@petadopt.ph
