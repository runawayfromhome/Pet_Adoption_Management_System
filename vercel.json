{
  "version": 2,
  "functions": {
    "api/index.py": {
      "includeFiles": [
        "api/templates/**",
        "api/static/**",
        "templates/**",
        "static/**",
        "../templates/**",
        "../static/**"
      ]
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}